# ═══════════════════════════════════════════════════════════════════════════════
# FlightScnr Pi — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# ALL configuration lives here — config.py reads exclusively from env vars.
# No defaults are hardcoded in source code for user-specific values.
#
# Setup:
#   cp .env.example .env
#   nano .env           # Fill in your values
#
# For systemd deployment, install-pi.sh copies .env to /etc/flightscnr.env
# ═══════════════════════════════════════════════════════════════════════════════
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ API Keys                                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# Required for the full experience:
#   FR24_API_KEY      — paid FR24 subscription (gRPC feed + flight details)
#   TOMORROW_API_KEY  — clock-screen weather (Tomorrow.io)
#
# Without FR24_API_KEY the app still runs on adsb.fi only (positions on radar,
# no routes/airline details/tracked flights). Set ADSB_ENABLED=True below.
# adsb.fi is a free cloud API — no local ADS-B receiver or dongle required.
#
# This is your FR24 subscription key — NOT the separate FR24 Explorer REST API.

# FlightRadar24 subscription key and token (format: "subscription_key|token")
FR24_API_KEY=

# Tomorrow.io weather API key (https://www.tomorrow.io/weather-api/)
TOMORROW_API_KEY=

# Optional — AirLabs schedule lookup when a flight is not airborne yet
#AIRLABS_API_KEY=

# Optional — aisstream.io AIS vessel feed (https://aisstream.io — free, non-commercial)
# Enable AIS data from the web portal Radar section or the on-device Settings screen.
#AISSTREAM_API_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Location (REQUIRED)                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘
# Minimum setup: set HOME_LAT and HOME_LON (your coordinates).
# A search zone is auto-built using SEARCH_RADIUS_NM (default 15nm).
# Or set all four zone corners manually (north-west and south-east).
# You can also set the radar center from the web portal (saved to location.json).

HOME_LAT= 37.619664
HOME_LON= -122.372035

# Search radius in nautical miles (used when only HOME_LAT/LON are set)
SEARCH_RADIUS_NM=15

# How often to poll adsb.fi / FR24 for fresh positions (seconds)
DATA_REFRESH_SECONDS=2

# How often to merge AIS vessels into the radar display (seconds).
# The aisstream WebSocket stays connected and pushes continuously; this only
# controls how often the UI re-reads the local vessel table.
AIS_REFRESH_SECONDS=5

# Optional manual bounding box (overrides auto zone when all four are set):
#ZONE_TL_LAT=
#ZONE_TL_LON=
#ZONE_BR_LAT=
#ZONE_BR_LON=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Weather                                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Comma-separated lat,lon for weather lookups (usually same as HOME_LAT,HOME_LON)
TEMPERATURE_LOCATION=

# Units: "metric" (°C) or "imperial" (°F). Portal weather settings override this after first save.
TEMPERATURE_UNITS=imperial

# Number of forecast days to display (1-5)
FORECAST_DAYS=3

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Display & Units                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Round touch display — panel resolution (rectangular framebuffer; round bezel masks corners).
# Use the native resolution of your panel; layout is centered on the visible circle.
DISPLAY_WIDTH=720
DISPLAY_HEIGHT=720

# Rotate the rendered UI clockwise: 0, 90, 180, or 270 degrees.
DISPLAY_ROTATION=90

# Fullscreen on the Pi (True/False). Set False for windowed dev on desktop.
DISPLAY_FULLSCREEN=True

# Flight detail: airline logo when no planespotters photo (True/False). Default off.
SHOW_AIRLINE_LOGOS=False

# AIS vessel radar declutter
VESSEL_SHORT_TAGS=True
VESSEL_HIDE_PARKED=True
VESSEL_HIERARCHY=True
# all_labels | moving_only | icons_only
VESSEL_DENSITY_MODE=moving_only
VESSEL_PARKED_SOG_KT=0.5

# Filter stuck capacitive jitter (ghost touches) before navigation. Set false to disable.
GHOST_TOUCH_FILTER=True

# Touch event path for taps/swipes.
# False (default): MOUSEBUTTON*/MOUSEMOTION — correct for Raspberry Pi OS Bookworm
# with labwc/Wayland + Xwayland, which pointer-emulates touch and never sends FINGER*.
# True: prefer SDL FINGER* when the stack actually delivers them (some capacitive DSI
# setups). If True but only mouse events arrive, the app falls back to mouse automatically.
TOUCH_USE_FINGER_EVENTS=False

# Verbose touch logging for journalctl (leave off in normal use).
#TOUCH_DEBUG=1

# Optional custom footer button PNGs (see flightscnr/buttons/).
# Leave unset to use the default buttons/ folder next to config.py.
#BUTTONS_DIR=/home/pi/my-button-art

# Radar map background (no API key)
#RADAR_MAP_ENABLED=True
# Default basemap when settings are first created (device Options / portal override):
#RADAR_MAP_PROVIDER=dark    # CARTO dark_nolabels (default; aliases: carto)
#RADAR_MAP_PROVIDER=light   # CARTO light_nolabels
#RADAR_MAP_PROVIDER=vfr     # FAA VFR sectional charts (US; public domain ArcGIS tiles)
#RADAR_MAP_PROVIDER=osm     # legacy dark-remapped OpenStreetMap tiles

# SDL video driver — on Pi with legacy framebuffer + X desktop, use x11:
SDL_VIDEODRIVER=x11

# Distance: "metric" (km) or "imperial" (miles)
DISTANCE_UNITS=metric

# Clock: "12hr" or "24hr"
CLOCK_FORMAT=24hr

# Display brightness (0-100) — used by settings screen
BRIGHTNESS=100

# Night-mode brightness (0-100, used when NIGHT_BRIGHTNESS=True)
BRIGHTNESS_NIGHT=50

# Enable night dimming? (True/False)
NIGHT_BRIGHTNESS=False

# Night mode time window (HH:MM format)
NIGHT_START=22:00
NIGHT_END=06:00

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Flight Filtering                                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

# Minimum altitude in feet — aircraft below this are hidden (0 = show all including ground)
MIN_HEIGHT=1000
#MIN_ALTITUDE=1000

# Live aircraft positions from adsb.fi (free, no key, no dongle). Merges with FR24 when both are on;
# becomes the sole radar data source when FR24_API_KEY is missing or unreachable.
ADSB_ENABLED=True

# Local dump1090-fa / readsb / tar1090 JSON feed (optional). Prefer local kinematics over adsb.fi.
#DUMP1090_ENABLED=False
#DUMP1090_URL=http://127.0.0.1:8080/data/aircraft.json

# Your home airport IATA code (e.g. LHR, ORD, JFK, SFO)
JOURNEY_CODE_SELECTED=

# Filler text shown when journey info is unknown
JOURNEY_BLANK_FILLER= ?

# Speed: "imperial" (mph), "metric" (km/h), or "knots"
SPEED_UNITS=metric

# Search radius in nautical miles from home for aircraft detection.
# If not set, computed from the bounding box (minimum 10nm).
#SEARCH_RADIUS_NM=10

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Web portal                                                                  │
# └─────────────────────────────────────────────────────────────────────────────┘

# HTTP port for the web portal (80 = http://hostname.local with no port in the URL).
# Requires root or CAP_NET_BIND_SERVICE for ports below 1024; flightscnr runs as root.
WEB_PORT=80

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ Logging & Notifications                                                     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Email address for alerts (leave empty to disable)
EMAIL=

# Optional map upload server for email alert links (leave empty to disable)
#MAP_UPLOAD_URL=https://your-server.example.com

# Number of farthest/closest flights to track
MAX_FARTHEST=3
MAX_CLOSEST=3

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AirLabs (optional — pre-departure tracked flights + flight detail routes)   │
# └─────────────────────────────────────────────────────────────────────────────┘
# Used when a tracked flight or web lookup is not yet airborne on FR24.
# Free tier: 1000 calls/month (https://airlabs.co/)
#AIRLABS_API_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ FlightAware AeroAPI (optional — route fallback only, not live radar)        │
# └─────────────────────────────────────────────────────────────────────────────┘
# Used when FR24 details and AirLabs lack origin/destination.
# Soft monthly spend ceiling protects free-tier credit (~$5/mo).
#FLIGHTAWARE_API_KEY=
#FLIGHTAWARE_MONTHLY_LIMIT=4.50
#FLIGHTAWARE_COST_PER_CALL=0.02
